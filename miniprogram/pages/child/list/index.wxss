.page {
  padding: 24rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

.loading-wrap {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.btn-add-empty {
  display: inline-block;
  background: #4F6EF7;
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 40rpx;
}

/* 孩子卡片 */
.child-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.child-card.active {
  border: 2rpx solid #4F6EF7;
}

.child-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4F6EF7, #7B93FA);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.child-detail {
  flex: 1;
  min-width: 0;
}

.child-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.child-meta {
  display: flex;
  gap: 12rpx;
}

.meta-tag {
  font-size: 24rpx;
  color: #999;
  background: #F5F6FA;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.current-badge {
  font-size: 24rpx;
  color: #4F6EF7;
  background: #EEF1FE;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

/* 操作按钮 */
.child-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
  justify-content: flex-end;
}

.btn-action {
  font-size: 26rpx;
  color: #4F6EF7;
  background: #EEF1FE;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
}

.btn-danger {
  color: #FF4D4F;
  background: #FFF1F0;
}

/* 添加按钮 */
.btn-add {
  text-align: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #4F6EF7;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-top: 8rpx;
}
