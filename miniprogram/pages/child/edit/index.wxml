<view class="page">
  <view class="card">
    <view wx:if="{{isOnboarding}}" class="onboarding-tip">
      <view class="tip-title">先添加第一个孩子</view>
      <view class="tip-sub">之后就可以为孩子创建作业、查看今日任务和学习周报。</view>
    </view>
    <input placeholder="孩子姓名" bindinput="onNameInput" value="{{name}}" />
    <picker mode="selector" range="{{['3-6','7-9','10-12']}}" value="{{ageIndex}}" bindchange="onAgeChange">
      <view class="picker">年龄段：{{ageGroup}}</view>
    </picker>
    <input placeholder="年级（可选）" bindinput="onGradeInput" value="{{grade}}" />
    <button type="primary" bindtap="onSubmit">保存</button>
  </view>
</view>
