.page { padding: 24rpx; }
.card { background: #fff; border-radius: 16rpx; padding: 24rpx; }
input,.picker { border: 1rpx solid #eee; border-radius: 12rpx; padding: 18rpx; margin-bottom: 16rpx; }


.onboarding-tip {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border-radius: 18rpx;
  background: #F5F7FF;
}

.tip-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.tip-sub {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
