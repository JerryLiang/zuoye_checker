.page {
  padding: 0;
  background: #F5F6FA;
  min-height: 100vh;
}

.profile-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4F6EF7 0%, #7B93FA 100%);
  padding: 48rpx 32rpx;
  color: #fff;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.child-count {
  font-size: 24rpx;
  opacity: 0.8;
}

.section {
  margin-top: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-left: 24rpx;
  margin-right: 24rpx;
  overflow: hidden;
}

.section-title {
  font-size: 24rpx;
  color: #999;
  padding: 20rpx 24rpx 0;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.arrow {
  color: #ccc;
  font-size: 28rpx;
}

.danger {
  color: #ee0a24;
}
