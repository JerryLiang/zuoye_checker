<view class="page">
  <!-- 用户信息卡片 -->
  <view class="profile-card">
    <view class="avatar">
      <text class="avatar-text">{{nickname[0]}}</text>
    </view>
    <view class="info">
      <text class="nickname">{{nickname}}</text>
      <text class="child-count">已添加 {{childCount}} 个孩子</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="section">
    <view class="section-title">孩子管理</view>
    <view class="menu-item" bindtap="goChildList">
      <text>孩子列表</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAddChild">
      <text>添加孩子</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">数据报告</view>
    <view class="menu-item" bindtap="goWeeklyReport">
      <text>学习周报</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">设置</view>
    <view class="menu-item" bindtap="onClearCache">
      <text class="danger">清除缓存</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
