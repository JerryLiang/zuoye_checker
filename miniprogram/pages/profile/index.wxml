<view class="page">
  <view class="profile-card">
    <view class="avatar">
      <text class="avatar-text">{{nickname[0]}}</text>
    </view>
    <view class="info">
      <text class="nickname">{{nickname}}</text>
      <text class="child-count">孩子端使用中，已添加 {{childCount}} 个孩子</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">身份</view>
    <view class="menu-item" bindtap="goRoleSelect">
      <text>切换孩子/家长身份</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goParentHome">
      <text>进入家长端</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">孩子端</view>
    <view class="menu-item" bindtap="goTodayTasks">
      <text>今日任务</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goReward">
      <text>我的奖励</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">设置</view>
    <view class="menu-item" bindtap="onClearCache">
      <text class="danger">清除缓存</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
