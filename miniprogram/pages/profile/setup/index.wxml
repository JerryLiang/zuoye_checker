<view class="page setup-page">
  <view class="hero-card">
    <view class="hero-icon">👋</view>
    <view class="hero-title">欢迎使用作业小卫士</view>
    <view class="hero-sub">请设置你的头像和昵称</view>
  </view>

  <view class="form-card">
    <view class="avatar-section">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="avatar-placeholder-text">+</text>
        </view>
        <view class="avatar-tip">点击选择头像</view>
      </button>
    </view>

    <view class="input-section">
      <view class="input-label">昵称</view>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="请输入昵称"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
    </view>

    <button class="submit-btn" bindtap="onSubmit" disabled="{{!nickname || loading}}">
      {{loading ? '保存中...' : '进入小程序'}}
    </button>

    <view class="skip-tip" bindtap="onSkip">暂时跳过</view>
  </view>
</view>
