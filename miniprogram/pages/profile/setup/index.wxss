.setup-page {
  padding-top: 60rpx;
}

.hero-card {
  padding: 48rpx 36rpx;
  margin-bottom: 36rpx;
  border-radius: 28rpx;
  color: #fff;
  text-align: center;
  background: linear-gradient(135deg, #4F6EF7 0%, #7B93FA 100%);
  box-shadow: 0 16rpx 36rpx rgba(79, 110, 247, 0.24);
}

.hero-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.9;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.05);
}

.avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}

.avatar-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  border: none;
  padding: 0;
  line-height: normal;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F5F6FA;
  margin-bottom: 12rpx;
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F5F6FA;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #ccc;
}

.avatar-placeholder-text {
  font-size: 64rpx;
  color: #bbb;
  line-height: 1;
}

.avatar-tip {
  font-size: 24rpx;
  color: #4F6EF7;
}

.input-section {
  margin-bottom: 48rpx;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.nickname-input {
  height: 88rpx;
  border: 2rpx solid #E8E8E8;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #333;
}

.nickname-input:focus {
  border-color: #4F6EF7;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #4F6EF7;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-bottom: 24rpx;
}

.submit-btn[disabled] {
  background: #B8C6F9;
  color: rgba(255, 255, 255, 0.8);
}

.skip-tip {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}
