<view class="page">
  <canvas canvas-id="compressCanvas" class="compress-canvas" style="width: {{canvasWidth}}px; height: {{canvasHeight}}px;"></canvas>
  <view class="card">
    <view class="mode-tabs">
      <view class="mode-tab {{inputMode === 'text' ? 'active' : ''}}" data-mode="text" bindtap="onModeChange">手动填写</view>
      <view class="mode-tab {{inputMode === 'photo' ? 'active' : ''}}" data-mode="photo" bindtap="onModeChange">图片识别</view>
    </view>

    <!-- 科目选择 -->
    <view class="form-group" wx:if="{{inputMode === 'text'}}">
      <text class="form-label">科目</text>
      <picker mode="selector" range="{{subjects}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-field">{{subject}} ▾</view>
      </picker>
    </view>

    <!-- 日期选择 -->
    <view class="form-group">
      <text class="form-label">作业日期</text>
      <picker mode="date" value="{{batchDate}}" bindchange="onDateChange">
        <view class="picker-field">{{batchDate}} ▾</view>
      </picker>
    </view>

    <!-- 图片上传 -->
    <view class="form-group" wx:if="{{inputMode === 'photo'}}">
      <text class="form-label">作业图片</text>
      <view class="image-grid" wx:if="{{imagePaths.length > 0}}">
        <view class="image-cell" wx:for="{{imagePaths}}" wx:key="index">
          <image class="preview-image" src="{{item}}" mode="aspectFill"></image>
          <view class="remove-image" data-index="{{index}}" catchtap="removeHomeworkImage">×</view>
        </view>
      </view>
      <view class="upload-box" bindtap="chooseHomeworkImage" wx:if="{{imagePaths.length < 5}}">
        <view class="upload-icon">🖼️</view>
        <view class="upload-text">拍照或从相册选择图片</view>
        <view class="upload-limit">还可上传 {{5 - imagePaths.length}} 张</view>
      </view>
      <view
        wx:if="{{fileAssetIds.length > 0}}"
        class="btn-recognize {{uploading || recognizing ? 'disabled' : ''}}"
        bindtap="recognizeUploadedImages"
      >
        {{recognizing ? '识别中...' : '上传识别'}}
      </view>
      <text class="form-hint">{{uploading ? '正在上传图片...' : (recognizing ? '正在识别作业内容...' : '单张不超过10M，一天作业最多5张；上传后点击“上传识别”再开始识别')}}</text>
    </view>

    <!-- 手动作业内容 -->
    <view class="form-group" wx:if="{{inputMode === 'text'}}">
      <view class="section-title-row">
        <text class="form-label no-margin">作业内容</text>
        <view class="add-btn" bindtap="addHomeworkItem">＋</view>
      </view>
      <view class="homework-input-row" wx:for="{{homeworkItems}}" wx:key="index">
        <input
          class="input-field homework-input"
          placeholder="请输入一条作业内容"
          data-index="{{index}}"
          bindinput="onTaskInput"
          value="{{item.text}}"
        />
        <view wx:if="{{homeworkItems.length > 1}}" class="remove-btn" data-index="{{index}}" bindtap="removeHomeworkItem">－</view>
      </view>
      <text class="form-hint">每一行会生成一个独立任务；点右上角加号新增一条</text>
    </view>

    <!-- 识别后的作业内容 -->
    <view class="form-group" wx:if="{{inputMode === 'photo'}}">
      <text class="form-label">作业内容</text>
      <view wx:if="{{recognizedItems.length > 0}}" class="recognized-list">
        <view class="recognized-item" wx:for="{{recognizedItems}}" wx:key="index">
          <picker mode="selector" range="{{subjects}}" data-index="{{index}}" bindchange="onRecognizedSubjectChange">
            <view class="recognized-subject">{{item.subject || '其他'}} ▾</view>
          </picker>
          <input
            class="input-field recognized-input"
            placeholder="可手动修改识别内容"
            data-index="{{index}}"
            bindinput="onRecognizedTextInput"
            value="{{item.text}}"
          />
        </view>
      </view>
      <view wx:else class="empty-recognized">
        {{recognizing ? '正在识别作业内容...' : (fileAssetIds.length > 0 ? '点击“上传识别”后，这里会列出可编辑的科目和作业内容' : '上传图片后，点击“上传识别”开始识别')}}
      </view>
    </view>

    <!-- 数学自动批改答案 -->
    <view class="form-group auto-check-card" wx:if="{{inputMode === 'text'}}">
      <view class="switch-row">
        <view>
          <text class="form-label inline-label">需要自动批改题目答案</text>
          <text class="form-hint no-margin">第一版仅支持数学科目</text>
        </view>
        <switch checked="{{autoCheckMath}}" disabled="{{subject !== '数学'}}" bindchange="onAutoCheckChange" />
      </view>
      <textarea
        wx:if="{{autoCheckMath}}"
        class="textarea-field answer-field"
        placeholder="请输入标准答案，每行对应上面一条任务&#10;例如：&#10;12&#10;36"
        bindinput="onAnswerInput"
        maxlength="-1"
        value="{{answerText}}"
      ></textarea>
    </view>

    <!-- 提交按钮 -->
    <view class="btn-primary {{submitting || uploading || recognizing ? 'disabled' : ''}}" bindtap="onSubmit">
      <text>{{submitting ? '提交中...' : '提交并生成任务'}}</text>
    </view>
  </view>
</view>
