<view class="page">
  <view class="card">
    <view class="mode-tabs">
      <view class="mode-tab {{inputMode === 'text' ? 'active' : ''}}" data-mode="text" bindtap="onModeChange">手动填写</view>
      <view class="mode-tab {{inputMode === 'photo' ? 'active' : ''}}" data-mode="photo" bindtap="onModeChange">拍照识别</view>
    </view>

    <!-- 科目选择 -->
    <view class="form-group">
      <text class="form-label">科目</text>
      <picker mode="selector" range="{{subjects}}" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-field">{{subject}} ▾</view>
      </picker>
    </view>

    <!-- 日期选择 -->
    <view class="form-group">
      <text class="form-label">作业日期</text>
      <picker mode="date" value="{{batchDate}}" bindchange="onDateChange">
        <view class="picker-field">{{batchDate}} ▾</view>
      </picker>
    </view>

    <!-- 拍照上传 -->
    <view class="form-group" wx:if="{{inputMode === 'photo'}}">
      <text class="form-label">作业图片</text>
      <view class="upload-box" bindtap="chooseHomeworkImage">
        <image wx:if="{{imagePath}}" class="preview-image" src="{{imagePath}}" mode="aspectFill"></image>
        <block wx:else>
          <view class="upload-icon">📷</view>
          <view class="upload-text">拍照或从相册上传</view>
        </block>
      </view>
      <text class="form-hint">{{recognizing ? '正在上传并识别...' : 'AI 会尝试识别日期、科目和作业内容，识别后请确认再提交'}}</text>
    </view>

    <!-- 作业内容 -->
    <view class="form-group">
      <text class="form-label">作业内容</text>
      <textarea
        class="textarea-field"
        placeholder="请输入作业内容，每行一个任务;例如：\n
        抄写生词3遍
        做练习册第5页"
        bindinput="onTextInput"
        maxlength="-1"
        value="{{rawText}}"
      ></textarea>
      <text class="form-hint">提示：每行会自动生成一个独立任务</text>
    </view>

    <!-- 数学自动批改答案 -->
    <view class="form-group auto-check-card">
      <view class="switch-row">
        <view>
          <text class="form-label inline-label">需要自动批改题目答案</text>
          <text class="form-hint no-margin">第一版仅支持数学科目</text>
        </view>
        <switch checked="{{autoCheckMath}}" disabled="{{subject !== '数学'}}" bindchange="onAutoCheckChange" />
      </view>
      <textarea
        wx:if="{{autoCheckMath}}"
        class="textarea-field answer-field"
        placeholder="请输入标准答案，每行对应上面一条任务&#10;例如：&#10;12&#10;36"
        bindinput="onAnswerInput"
        maxlength="-1"
        value="{{answerText}}"
      ></textarea>
    </view>

    <!-- 提交按钮 -->
    <view class="btn-primary {{submitting || recognizing ? 'disabled' : ''}}" bindtap="onSubmit">
      <text>{{submitting ? '提交中...' : '提交并生成任务'}}</text>
    </view>
  </view>
</view>
