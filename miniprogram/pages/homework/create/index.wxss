.page {
  padding: 24rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

.compress-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  opacity: 0;
  pointer-events: none;
}

.mode-tabs {
  display: flex;
  padding: 8rpx;
  margin-bottom: 28rpx;
  background: #F5F6FA;
  border-radius: 18rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #666;
}

.mode-tab.active {
  background: #ffffff;
  color: #4F6EF7;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.12);
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.inline-label {
  margin-bottom: 4rpx;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.no-margin {
  margin: 0;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.add-btn,
.remove-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
}

.add-btn {
  color: #fff;
  background: #4F6EF7;
}

.remove-btn {
  flex-shrink: 0;
  color: #999;
  background: #F0F2F7;
}

.homework-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.homework-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  line-height: 44rpx;
  margin-bottom: 0;
}

.upload-box {
  height: 220rpx;
  border: 2rpx dashed #D8DCE8;
  border-radius: 18rpx;
  background: #FAFBFE;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #666;
}

.upload-limit {
  margin-top: 8rpx;
  color: #999;
  font-size: 22rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.image-cell {
  position: relative;
  height: 160rpx;
  border-radius: 14rpx;
  overflow: hidden;
  background: #F0F2F7;
}

.remove-image {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 34rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
  font-size: 30rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.recognized-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.recognized-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #FAFBFE;
  border: 1rpx solid #ECEFF6;
}

.recognized-subject {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  color: #4F6EF7;
  background: rgba(79, 110, 247, 0.1);
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.recognized-text {
  color: #333;
  font-size: 28rpx;
  line-height: 1.5;
}

.empty-recognized {
  padding: 28rpx;
  border-radius: 16rpx;
  color: #999;
  background: #FAFBFE;
  font-size: 26rpx;
  text-align: center;
}

.auto-check-card {
  padding: 22rpx;
  background: #FAFBFE;
  border-radius: 18rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.answer-field {
  margin-top: 20rpx;
}

.btn-primary {
  margin-top: 16rpx;
}

.btn-primary.disabled {
  opacity: 0.6;
}


.btn-recognize {
  margin-top: 16rpx;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 16rpx;
  color: #fff;
  background: #4F6EF7;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-recognize.disabled {
  opacity: 0.6;
}

.recognized-input {
  margin-top: 10rpx;
  width: 100%;
  min-height: 170rpx;
  box-sizing: border-box;
  line-height: 1.5;
  margin-bottom: 0;
}
