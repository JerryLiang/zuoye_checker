.page {
  padding: 24rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

.mode-tabs {
  display: flex;
  padding: 8rpx;
  margin-bottom: 28rpx;
  background: #F5F6FA;
  border-radius: 18rpx;
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #666;
}

.mode-tab.active {
  background: #ffffff;
  color: #4F6EF7;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(79, 110, 247, 0.12);
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.inline-label {
  margin-bottom: 4rpx;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.no-margin {
  margin: 0;
}

.upload-box {
  height: 260rpx;
  border: 2rpx dashed #D8DCE8;
  border-radius: 18rpx;
  background: #FAFBFE;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #666;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.auto-check-card {
  padding: 22rpx;
  background: #FAFBFE;
  border-radius: 18rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.answer-field {
  margin-top: 20rpx;
}

.btn-primary {
  margin-top: 16rpx;
}

.btn-primary.disabled {
  opacity: 0.6;
}
