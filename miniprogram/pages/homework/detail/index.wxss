.page {
  padding: 24rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

.loading-wrap {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 批次信息卡片 */
.batch-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.batch-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.subject-tag {
  font-size: 28rpx;
  font-weight: 600;
  color: #4F6EF7;
  background: #EEF1FE;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
}

.batch-date {
  font-size: 26rpx;
  color: #999;
}

.batch-progress {
  margin-bottom: 16rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
}

.progress-pct {
  font-size: 26rpx;
  color: #4F6EF7;
  font-weight: 600;
}

.progress-bar {
  height: 12rpx;
  background: #E8EAF0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F6EF7, #7B93FA);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.raw-text {
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.raw-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.raw-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

/* 任务卡片 */
.task-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.task-card.done {
  opacity: 0.7;
}

.task-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.task-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
}

.task-check.checked {
  background: #52C41A;
}

.task-check.pending {
  border: 3rpx solid #D9D9D9;
}

.task-title {
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.tag-done {
  background: #F0FFF4;
  color: #52C41A;
}

.tag-pending {
  background: #FFF7E6;
  color: #FA8C16;
}

/* 提交信息 */
.submission-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-badge {
  font-size: 26rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.score-badge.pass {
  background: #F0FFF4;
  color: #52C41A;
}

.score-badge.fail {
  background: #FFF1F0;
  color: #FF4D4F;
}

.feedback {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 操作按钮 */
.task-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
  display: flex;
  justify-content: flex-end;
}

.btn-submit {
  font-size: 26rpx;
  color: #4F6EF7;
  background: #EEF1FE;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
  padding-bottom: 40rpx;
}

.btn-refresh {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #4F6EF7;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.btn-delete {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #FF4D4F;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.empty-state {
  text-align: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
