.page {
  padding: 24rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

.loading-wrap {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
}

/* 周导航 */
.week-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.nav-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #4F6EF7;
  background: #EEF1FE;
  border-radius: 50%;
}

.week-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 汇总网格 */
.summary-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.summary-item {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.summary-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #4F6EF7;
  margin-bottom: 4rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #999;
}

/* 积分条 */
.points-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #4F6EF7, #7B93FA);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 28rpx;
}

.points-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.points-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}

/* 区块标题 */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

/* 每日详情 */
.daily-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.daily-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.daily-item.all-done {
  border-left: 6rpx solid #52C41A;
}

.day-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.day-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.day-date {
  font-size: 24rpx;
  color: #999;
}

.day-stats {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.day-progress {
  font-size: 24rpx;
  color: #4F6EF7;
  width: 72rpx;
  flex-shrink: 0;
}

.day-bar {
  flex: 1;
  height: 12rpx;
  background: #E8EAF0;
  border-radius: 6rpx;
  overflow: hidden;
}

.day-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F6EF7, #7B93FA);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.day-score {
  font-size: 24rpx;
  color: #666;
  width: 80rpx;
  text-align: right;
  flex-shrink: 0;
}

.day-empty {
  font-size: 24rpx;
  color: #ccc;
}

/* 刷新 */
.refresh-btn {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 32rpx 0;
  margin-top: 16rpx;
}
