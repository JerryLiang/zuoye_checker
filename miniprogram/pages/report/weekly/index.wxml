<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>

  <!-- 未选择孩子 -->
  <view wx:elif="{{!report}}" class="empty-state">
    <view class="empty-icon">📊</view>
    <view class="empty-text">请先在首页选择孩子</view>
  </view>

  <block wx:else>
    <!-- 周切换 -->
    <view class="week-nav">
      <view class="nav-btn" bindtap="onPrevWeek">&lt;</view>
      <text class="week-label">{{weekLabel}}</text>
      <view class="nav-btn" bindtap="onNextWeek">&gt;</view>
    </view>

    <!-- 汇总卡片 -->
    <view class="summary-grid">
      <view class="summary-item">
        <text class="summary-value">{{report.summary.total_tasks}}</text>
        <text class="summary-label">总任务</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{report.summary.completed_tasks}}</text>
        <text class="summary-label">已完成</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{report.summary.completion_rate}}%</text>
        <text class="summary-label">完成率</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{report.summary.avg_score}}</text>
        <text class="summary-label">平均分</text>
      </view>
    </view>

    <!-- 积分条 -->
    <view class="points-bar">
      <text class="points-label">本周获得积分</text>
      <text class="points-value">{{report.summary.total_points}}</text>
    </view>

    <!-- 每日详情 -->
    <view class="section-title">每日详情</view>
    <view class="daily-list">
      <view
        wx:for="{{report.daily_stats}}"
        wx:key="date"
        class="daily-item {{item.total > 0 && item.completed === item.total ? 'all-done' : ''}}"
      >
        <view class="day-header">
          <text class="day-name">{{item.weekday}}</text>
          <text class="day-date">{{item.date}}</text>
        </view>
        <view class="day-stats" wx:if="{{item.total > 0}}">
          <text class="day-progress">{{item.completed}}/{{item.total}}</text>
          <view class="day-bar">
            <view class="day-fill" style="width: {{item.total > 0 ? (item.completed / item.total * 100) : 0}}%"></view>
          </view>
          <text class="day-score">{{item.avg_score}}分</text>
        </view>
        <text class="day-empty" wx:else>无任务</text>
      </view>
    </view>

    <!-- 刷新 -->
    <view class="refresh-btn" bindtap="onRefresh">刷新</view>
  </block>
</view>
