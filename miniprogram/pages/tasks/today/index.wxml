<view class="page">
  <!-- 日期头部 -->
  <view class="date-header">
    <text class="date-text">{{currentDate}}</text>
    <text class="task-count" wx:if="{{totalTasks > 0}}">{{doneTasks}}/{{totalTasks}} 已完成</text>
  </view>

  <!-- 进度条 -->
  <view class="progress-wrap" wx:if="{{totalTasks > 0}}">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{totalTasks > 0 ? (doneTasks / totalTasks * 100) : 0}}%"></view>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{tasks.length === 0}}" class="empty-state">
    <view class="empty-icon">📋</view>
    <view class="empty-text">今天还没有任务</view>
    <view class="empty-sub">去首页创建作业吧</view>
  </view>

  <!-- 任务列表 -->
  <block wx:else>
    <view
      wx:for="{{tasks}}"
      wx:key="_id"
      class="task-card {{item.status === 2 ? 'done' : (item.status === 3 ? 'submitted' : '')}}"
      data-id="{{item._id}}"
      data-status="{{item.status}}"
      bindtap="goSubmit"
    >
      <view class="task-header">
        <view class="task-left">
          <view class="task-check {{item.status === 2 ? 'checked' : (item.status === 3 ? 'submitted' : '')}}">
            <text wx:if="{{item.status === 2}}">✓</text>
            <text wx:elif="{{item.status === 3}}">…</text>
          </view>
          <text class="task-title">{{item.title}}</text>
        </view>
        <text class="tag {{item.status === 2 ? 'tag-done' : (item.status === 3 ? 'tag-submitted' : 'tag-pending')}}">
          {{item.status === 2 ? '已完成' : (item.status === 3 ? '已提交' : '待完成')}}
        </text>
      </view>
      <view class="task-actions">
        <view class="btn-submit" data-id="{{item._id}}" data-status="{{item.status}}" catchtap="goSubmit">
          {{canManage ? '查看' : (item.status === 2 ? '查看' : (item.status === 3 ? '修改' : '去完成'))}}
        </view>
        <view wx:if="{{canManage && item.status === 1}}" class="btn-submit danger" data-id="{{item._id}}" catchtap="onDeleteTask">删除</view>
      </view>
    </view>
  </block>

  <!-- 刷新按钮 -->
  <view class="refresh-btn" bindtap="onRefresh" wx:if="{{!loading && tasks.length > 0}}">
    刷新任务
  </view>
</view>
