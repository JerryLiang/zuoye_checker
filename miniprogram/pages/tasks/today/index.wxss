.page {
  padding: 24rpx;
  background: #F5F6FA;
  min-height: 100vh;
}

.date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0 20rpx;
}

.date-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.task-count {
  font-size: 26rpx;
  color: #4F6EF7;
  font-weight: 500;
}

.progress-wrap {
  margin-bottom: 28rpx;
}

.progress-bar {
  height: 12rpx;
  background: #E8EAF0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F6EF7, #7B93FA);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 任务卡片 */
.task-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.task-card.done {
  opacity: 0.65;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.task-check {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid #D9D9D9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #fff;
}

.task-check.checked {
  background: #52C41A;
  border-color: #52C41A;
}

.task-title {
  font-size: 30rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F5F5F5;
  display: flex;
  justify-content: flex-end;
}

.btn-submit {
  font-size: 26rpx;
  color: #4F6EF7;
  background: #EEF1FE;
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
}

.refresh-btn {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 32rpx 0;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #999;
}
