<view class="page">
  <view class="card">
    <view class="form-group">
      <text class="form-label">作业答案</text>
      <textarea
        class="textarea-field"
        placeholder="请输入作业完成内容或答案描述..."
        bindinput="onTextInput"
        maxlength="-1"
        value="{{text}}"
      ></textarea>
    </view>

    <view class="btn-primary" bindtap="onSubmit">
      <text>{{submitting ? '提交中...' : '提交检查'}}</text>
    </view>
  </view>
</view>
