.role-page {
  padding-top: 80rpx;
}

.hero-card {
  padding: 56rpx 36rpx;
  margin-bottom: 36rpx;
  border-radius: 28rpx;
  color: #fff;
  text-align: center;
  background: linear-gradient(135deg, #4F6EF7 0%, #7B93FA 100%);
  box-shadow: 0 16rpx 36rpx rgba(79, 110, 247, 0.24);
}

.hero-icon {
  font-size: 76rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 26rpx;
  opacity: 0.9;
}

.role-card {
  display: flex;
  align-items: center;
  padding: 34rpx 30rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.05);
}

.role-card.parent {
  border: 2rpx solid rgba(79, 110, 247, 0.16);
}

.role-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  border-radius: 28rpx;
  font-size: 44rpx;
  background: #F5F6FA;
}

.role-content {
  flex: 1;
}

.role-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 8rpx;
}

.role-desc {
  font-size: 25rpx;
  color: #777;
  line-height: 1.5;
}

.role-arrow {
  color: #bbb;
  font-size: 54rpx;
}
