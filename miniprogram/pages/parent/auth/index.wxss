.auth-card {
  margin-top: 96rpx;
  padding: 52rpx 34rpx;
  border-radius: 28rpx;
  background: #fff;
  text-align: center;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
}

.lock-icon {
  font-size: 82rpx;
  margin-bottom: 20rpx;
}

.auth-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.auth-desc {
  font-size: 26rpx;
  color: #777;
  margin-bottom: 42rpx;
}

.pin-input {
  height: 92rpx;
  margin-bottom: 32rpx;
  border-radius: 18rpx;
  background: #F5F6FA;
  font-size: 34rpx;
  text-align: center;
  letter-spacing: 8rpx;
}

.auth-btn {
  margin-bottom: 24rpx;
}

.auth-tip {
  font-size: 24rpx;
  color: #999;
}
