.parent-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 34rpx;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #4F6EF7 0%, #7B93FA 100%);
}

.parent-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.parent-sub {
  font-size: 26rpx;
  opacity: 0.9;
}

.role-switch {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 24rpx;
}

.child-scroll {
  white-space: nowrap;
}

.child-pills {
  display: flex;
  gap: 16rpx;
}

.child-pill {
  display: inline-flex;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  color: #666;
  background: #F5F6FA;
}

.child-pill.active {
  color: #fff;
  background: #4F6EF7;
}

.overview-row {
  display: flex;
  gap: 20rpx;
}

.overview-item {
  flex: 1;
  padding: 26rpx;
  border-radius: 20rpx;
  background: #F7F8FF;
  text-align: center;
}

.overview-item.tappable {
  border: 1rpx solid rgba(79, 110, 247, 0.18);
}

.overview-number {
  font-size: 46rpx;
  font-weight: 800;
  color: #4F6EF7;
}

.overview-number.done {
  color: #52C41A;
}

.overview-number.submitted {
  color: #FA8C16;
}

.overview-label {
  font-size: 24rpx;
  color: #777;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 150rpx;
  border-radius: 20rpx;
  background: #F8F9FC;
  color: #333;
  font-size: 26rpx;
}

.action-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border-radius: 20rpx;
  font-size: 34rpx;
}

.action-icon.blue { background: #EEF2FF; }
.action-icon.purple { background: #F5EEFF; }
.action-icon.green { background: #EFFFF4; }
.action-icon.orange { background: #FFF7E6; }

.logout-btn {
  margin-top: 20rpx;
}
