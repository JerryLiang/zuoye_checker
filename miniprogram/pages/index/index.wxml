<view class="page">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 欢迎横幅 -->
    <view class="hero-banner">
      <view class="hero-title">{{greeting}}，家长</view>
      <view class="hero-sub" wx:if="{{currentChild}}">{{currentChild.name}} 的学习之旅</view>
      <view class="hero-sub" wx:else>请先添加孩子信息</view>
    </view>

    <!-- 孩子切换 -->
    <view class="card" wx:if="{{children.length > 0}}">
      <view class="section-title">切换孩子</view>
      <scroll-view scroll-x class="child-scroll">
        <view class="child-pills">
          <view
            wx:for="{{children}}"
            wx:key="id"
            class="child-pill {{currentChildId === item.id ? 'active' : ''}}"
            data-id="{{item.id}}"
            bindtap="onSelectChild"
          >
            {{item.name}}
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 无孩子提示 -->
    <view class="card empty-state" wx:if="{{children.length === 0}}">
      <view class="empty-icon">👋</view>
      <view class="empty-text">还没有添加孩子信息</view>
      <view class="btn-primary" style="margin-top: 24rpx;" bindtap="goAddChild">+ 添加孩子</view>
    </view>

    <!-- 今日任务概览 -->
    <view class="card" wx:if="{{currentChild}}">
      <view class="section-title">今日任务</view>

      <!-- 进度条 -->
      <view class="progress-wrap" wx:if="{{todayTotal > 0}}">
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{todayTotal > 0 ? (todayDone / todayTotal * 100) : 0}}%"></view>
        </view>
        <view class="progress-text">{{todayDone}}/{{todayTotal}} 已完成</view>
      </view>

      <!-- 任务列表 -->
      <view wx:if="{{todayTasks.length === 0}}" class="empty-hint">
        暂无任务，点击下方按钮创建作业
      </view>

      <view
        wx:for="{{todayTasks}}"
        wx:key="id"
        class="task-item {{item.status === 2 ? 'done' : ''}}"
      >
        <view class="task-left">
          <view class="task-dot {{item.status === 2 ? 'done' : ''}}"></view>
          <text class="task-title">{{item.title}}</text>
        </view>
        <view class="task-right">
          <text class="tag {{item.status === 2 ? 'tag-done' : 'tag-pending'}}">
            {{item.status === 2 ? '已完成' : '待完成'}}
          </text>
          <view wx:if="{{item.status !== 2}}" class="btn-go" data-id="{{item.id}}" bindtap="goTaskSubmit">
            去完成
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="card" wx:if="{{currentChild}}">
      <view class="section-title">快捷操作</view>
      <view class="action-grid">
        <view class="action-item" bindtap="goCreateHomework">
          <view class="action-icon blue">📝</view>
          <text>创建作业</text>
        </view>
        <view class="action-item" bindtap="goWeeklyReport">
          <view class="action-icon purple">📊</view>
          <text>学习周报</text>
        </view>
        <view class="action-item" bindtap="goAddChild">
          <view class="action-icon green">👶</view>
          <text>添加孩子</text>
        </view>
      </view>
    </view>
  </block>
</view>
