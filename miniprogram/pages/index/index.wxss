/* 首页样式 */

/* 横幅 */
.hero-banner {
  background: linear-gradient(135deg, #4F6EF7 0%, #7B93FA 100%);
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.hero-banner .hero-title {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.hero-banner .hero-sub {
  font-size: 26rpx;
  opacity: 0.85;
}

/* 孩子选择滚动 */
.child-scroll {
  white-space: nowrap;
}

.child-pills {
  display: flex;
  gap: 16rpx;
}

.child-pill {
  display: inline-block;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #F5F6FA;
  color: #666;
  flex-shrink: 0;
}

.child-pill.active {
  background: #4F6EF7;
  color: #fff;
}

/* 进度条 */
.progress-wrap {
  margin-bottom: 24rpx;
}

.progress-bar {
  height: 16rpx;
  background: #E8EAF0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4F6EF7, #7B93FA);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  text-align: right;
}

/* 任务列表 */
.task-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.task-item:last-child {
  border-bottom: none;
}

.task-item.done {
  opacity: 0.6;
}

.task-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.task-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FA8C16;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.task-dot.done {
  background: #52C41A;
}

.task-title {
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.btn-go {
  font-size: 24rpx;
  color: #4F6EF7;
  background: #EEF1FE;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.empty-hint {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 30rpx 0;
}

/* 快捷操作 */
.action-grid {
  display: flex;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: #FAFBFE;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-icon.blue {
  background: #EEF1FE;
}

.action-icon.green {
  background: #E8F8EE;
}

.action-icon.purple {
  background: #F3EEFF;
}
